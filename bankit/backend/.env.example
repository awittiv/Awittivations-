# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...          # Project Settings → API → service_role
SUPABASE_JWT_SECRET=your-jwt-secret              # Project Settings → API → JWT Secret

# ─── Polygon / Web3 ──────────────────────────────────────────────────────────
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
ORACLE_PUBLIC_KEY=0xYourOracleWalletAddress
ORACLE_PRIVATE_KEY=0xYourPrivateKey              # NEVER COMMIT

# After: forge script script/Deploy.s.sol --rpc-url amoy --broadcast
CONTRACT_ADDRESS=0xDeployedBankitLiquidityRouterAddress
STABLECOIN_ADDRESS=0xDeployedBankitStablecoinAddress

# ─── AI ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── WhatsApp / Twilio ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── TPAP Corridor ───────────────────────────────────────────────────────────
GATEWAY_API_TOKEN=your-secret-gateway-token

# ─── Webhooks ────────────────────────────────────────────────────────────────
