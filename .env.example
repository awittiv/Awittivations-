# ─── Anthropic ────────────────────────────────────────────────────────────────
# Required: your Anthropic API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model (default: claude-3-5-sonnet-20241022)
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Required: your bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Optional: message parse mode (default: HTML)
TELEGRAM_PARSE_MODE=HTML

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Optional: comma-separated list of allowed origins (default: * for development)
# In production, set this to your frontend domain, e.g.:
#   ALLOWED_ORIGINS=https://yourapp.com,https://www.yourapp.com
ALLOWED_ORIGINS=*

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=awittivations
DB_USER=postgres
DB_PASSWORD=postgres

# ─── HubSpot Integration ──────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=pat-na1-...
