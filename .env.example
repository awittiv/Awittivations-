# Copy this file to .env and fill in real values
# Do NOT commit .env — only commit this file

MONGO_HOST=mongodb+srv://cluster0.example.mongodb.net
MONGO_DB_NAME=my_database
MONGO_USER=your_mongo_user
MONGO_PASSWORD=your_mongo_password

# HubSpot × Bankit CrewAI integration
HUBSPOT_API_TOKEN=your_hubspot_private_app_token
BANKIT_API_URL=http://localhost:8000

# Sales outreach crew
SENDGRID_API_KEY=your_sendgrid_api_key
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
CALENDLY_API_TOKEN=your_calendly_api_token
CALENDLY_LINK=https://calendly.com/awittivations/intro
SENDER_EMAIL=hello@awittivations.com
LEAD_LINKEDIN_URL=
LEAD_EMAIL=
