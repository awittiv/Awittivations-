# This repository was initialized in $HOME, which is full of unrelated dotfiles,
# caches, and personal files (Desktop/, Downloads/, *.pdf, .ssh/, .config/, ...).
# Strategy: ignore EVERYTHING at the repo root, then explicitly allow-list the
# project directories and files we actually track. A new top-level project must
# be added here before git will see it.
/*

# Repo meta + known projects (the only things tracked at the root)
!/.gitignore
!/.env.example
!/aurax/
!/Banking/
!/bankit/
!/burf/
!/cuneiform-translator/
!/launchlayer/
!/orchestrater\ /
!/project-dashboard/
!/telegram_bot.py

# Within the allowed projects, still ignore the usual noise. These patterns are
# non-rooted, so they match at any depth and re-exclude paths inside the
# allow-listed directories above.

# Environment variables — never commit secrets
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
.Python

# Node
node_modules/

# Python virtualenvs
*-env/
.venv/
venv/

# Logs
*.log

# Misc
*.swp
*.save
*.save.*
