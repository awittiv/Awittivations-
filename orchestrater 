@app.post("/telegram/webhook")
async def telegram_webhook(request: Request):
    """
    Telegram Bot webhook. Registered via /telegram/register-webhook.
    Every message sent to your bot arrives here.
    """
    try:
        update = await request.json()
    except Exception:
        raise HTTPException(status_code=400, detail="Invalid JSON from Telegram.")

    message = update.get("message") or update.get("edited_message")
    if not message:
        return {"ok": True}   # ignore non-message updates (joins, etc.)

    chat_id  = message["chat"]["id"]
    text     = message.get("text", "").strip()
    username = message.get("from", {}).get("username", "user")

    # Ignore commands except /start
    if text.startswith("/start"):
        await tg.send_message(
            chat_id,
            "⬡ <b>Awittivations AI Orchestrator</b>\n\n"
            "Send me any financial question and I'll route it to the right agent:\n\n"
            "◈ <b>CashPilot</b> — cash flow, payroll, runway\n"
            "◎ <b>Bankit</b> — crypto, USDC, on-chain payments\n"
            "◉ <b>PulseAI</b> — market news, interest rates\n"
            "⬡ <b>Orchestrator</b> — strategy, onboarding\n\n"
            "<i>Just type your question to get started.</i>",
        )
        return {"ok": True}

    if not text or text.startswith("/"):
        return {"ok": True}

    # Show typing indicator
    await tg.send_typing(chat_id)

    # Build orchestration request
    req = TaskRequest(
        task=text,
        channel=Channel.TELEGRAM,
        session_id=str(chat_id),
    )

    try:
        result = await orchestrate(req)
        result_dict = result.model_dump()
    except HTTPException as e:
        await tg.send_message(chat_id, f"⚠ Orchestrator error: {e.detail}")
        return {"ok": True}

    if result.requires_human_review:
        await tg.send_message(chat_id, tg.format_review_request(result_dict))
    else:
        await tg.send_message(chat_id, tg.format_response(result_dict))

    return {"ok": True}


