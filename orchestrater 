@app.post("/orchestrate", response_model=OrchestratorResponse)
async def orchestrate(req: TaskRequest):
    t0 = time.time()

    messages = req.history[-6:] + [
        {"role": "user", "content": f"Channel: {req.channel.value.upper()}\nTask: {req.task}"}
    ]

    try:
        api_response = client.messages.create(
            model="claude-opus-4-6",
            max_tokens=1024,
            system=ORCHESTRATOR_SYSTEM,
            messages=messages,
        )
        raw = api_response.content[0].text
    except anthropic.APIError as e:
        raise HTTPException(status_code=503, detail=f"LLM service error: {str(e)}")

    try:
        llm_result = json.loads(raw.replace("```json", "").replace("```", "").strip())
    except json.JSONDecodeError:
        raise HTTPException(status_code=502, detail="Blueprint parse failed — LLM returned non-JSON.")

    try:
        agent = AgentType(llm_result["agent"])
    except (ValueError, KeyError):
        agent = AgentType.ORCHESTRATOR

    try:
        blueprint_type = BlueprintType(llm_result.get("blueprint_type", "agent_loop"))
    except ValueError:
        blueprint_type = BlueprintType.AGENT_LOOP

    confidence     = int(llm_result.get("confidence", 75))
    response_text  = llm_result.get("response", "")
    actions        = llm_result.get("actions", [])

    wedge = run_wedge_engine(response_text)
    if not wedge.passed:
        blueprint_type = BlueprintType.DETERMINISTIC

    requires_review, review_reason = needs_human_review(req.task, agent, confidence)

    latency_ms   = int((time.time() - t0) * 1000)
    blueprint_id = hashlib.sha256(
        f"{req.task}:{agent.value}:{t0}".encode()
    ).hexdigest()[:16]

    return OrchestratorResponse(
        agent=agent,
        blueprint_type=blueprint_type,
        wedge=wedge,
        requires_human_review=requires_review,
        review_reason=review_reason,
        response=response_text,
        confidence=confidence,
        actions=actions,
        latency_ms=latency_ms,
        blueprint_id=blueprint_id,
    )


