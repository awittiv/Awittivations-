# ─── Wedge Engine v1 ─────────────────────────────────────────────────────────

PROHIBITED_PHRASES = [
    "guaranteed returns", "risk-free", "get rich quick",
    "no risk", "guaranteed profit", "100% safe",
    "zero risk", "certain returns",
]

JARGON_TERMS = [
    "derivative", "securitization", "collateral", "covenant",
    "tranche", "amortization", "subordinated", "encumbrance",
]

def run_wedge_engine(text: str) -> WedgeResult:
    flags = []
    lower = text.lower()

    for phrase in PROHIBITED_PHRASES:
        if phrase in lower:
            flags.append(f'prohibited: "{phrase}"')

    words = text.split()
    avg_word_len = sum(len(w) for w in words) / max(len(words), 1)
    jargon_count = sum(1 for t in JARGON_TERMS if t in lower)
    base_score = max(0, 100 - int(avg_word_len * 6) - (jargon_count * 12))
    accessibility_score = min(100, max(0, base_score))

    dialect_note = None
    if accessibility_score < 50:
        dialect_note = "Response complexity elevated — recommend simplification pass."

    return WedgeResult(
        passed=len(flags) == 0,
        flags=flags,
        accessibility_score=accessibility_score,
        dialect_note=dialect_note,
    )

# ─── Human Review Gate ───────────────────────────────────────────────────────

def needs_human_review(
    task: str, agent: AgentType, confidence: int
) -> tuple[bool, Optional[str]]:
    lower = task.lower()

    if any(kw in lower for kw in ["tax advice", "legal", "lawsuit", "file taxes", "irs"]):
        return True, "Task involves legal or tax guidance — requires licensed professional review."

    if any(kw in lower for kw in ["can't pay", "eviction", "bankruptcy", "losing everything", "shutting down"]):
        return True, "User may be in financial distress — escalating for compassionate human review."

    threshold = BLUEPRINTS[agent].get("human_review_threshold")
    if threshold:
        amounts = re.findall(r'\$[\d,]+(?:\.\d{2})?|\d[\d,]+\s*(?:dollars|USD|USDC)', task)
        for amount_str in amounts:
            numeric = re.sub(r'[^\d.]', '', amount_str)
            try:
                if float(numeric) >= threshold:
                    return True, f"Implied transaction ≥ ${threshold:,} — requires human review per compliance policy."
            except ValueError:
                pass

    if confidence < 50:
        return True, "Orchestrator confidence below threshold — human review recommended."

    return False, None

